{
  "name": "web-agent-runtime-workspace",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n runtime,demo -c blue,green \"pnpm --filter web-agent-runtime dev\" \"pnpm --filter web-agent-runtime-demo dev\"",
    "start:runtime": "pnpm --filter web-agent-runtime dev",
    "start:demo": "pnpm --filter web-agent-runtime-demo dev",
    "build": "pnpm --filter web-agent-runtime build && pnpm --filter web-agent-runtime-demo build",
    "typecheck": "pnpm --filter web-agent-runtime typecheck && pnpm --filter web-agent-runtime typecheck:test && pnpm --filter web-agent-runtime-demo typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "node -e \"import('husky').then(m=>m.default()).catch(()=>{})\""
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.38.0"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
